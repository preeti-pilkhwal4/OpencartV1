version: "3.9"

services:
  selenium-hub:
    image: selenium/hub:4.12.1
    container_name: selenium-hub
    ports:
      - "4444:4444"   # Hub console
      - "4442:4442"   # Event bus
      - "4443:4443"   # Event bus
    networks:
      - grid

  node-chrome:
    image: selenium/node-chrome:4.12.1
    container_name: node-chrome
    shm_size: 2g             # Increase /dev/shm to prevent Chrome crashes
    environment:
      - SE_EVENT_BUS_HOST=selenium-hub
      - SE_EVENT_BUS_PUBLISH_PORT=4442
      - SE_EVENT_BUS_SUBSCRIBE_PORT=4443
      - SE_NODE_MAX_SESSIONS=5
      - SE_NODE_OVERRIDE_MAX_SESSIONS=true
      - SE_NODE_HEADLESS=true
    command: >
      selenium-node
      --disable-dev-shm-usage
      --no-sandbox
      --disable-gpu
    networks:
      - grid

  node-firefox:
    image: selenium/node-firefox:4.12.1
    container_name: node-firefox
    shm_size: 2g
    environment:
      - SE_EVENT_BUS_HOST=selenium-hub
      - SE_EVENT_BUS_PUBLISH_PORT=4442
      - SE_EVENT_BUS_SUBSCRIBE_PORT=4443
      - SE_NODE_HEADLESS=true
    command: >
      selenium-node
      --disable-dev-shm-usage
      --no-sandbox
    networks:
      - grid

networks:
  grid:
    driver: bridge
