services:
  selenium-hub:
    image: selenium/hub:4.12.1
    container_name: selenium-hub
    ports:
      - "4444:4444"
      - "4442:4442"
      - "4443:4443"
    networks:
      - grid

  node-chrome:
    image: selenium/node-chrome:4.12.1
    container_name: node-chrome
    shm_size: 2g
    environment:
      - SE_EVENT_BUS_HOST=selenium-hub
      - SE_EVENT_BUS_PUBLISH_PORT=4442
      - SE_EVENT_BUS_SUBSCRIBE_PORT=4443
      - SE_NODE_MAX_SESSIONS=5
      - SE_NODE_OVERRIDE_MAX_SESSIONS=true
      - SE_NODE_HEADLESS=true
      - SE_OPTS=--disable-dev-shm-usage --no-sandbox --disable-gpu --remote-debugging-port=9222
    networks:
      - grid

  node-firefox:
    image: selenium/node-firefox:4.12.1
    container_name: node-firefox
    shm_size: 2g
    environment:
      - SE_EVENT_BUS_HOST=selenium-hub
      - SE_EVENT_BUS_PUBLISH_PORT=4442
      - SE_EVENT_BUS_SUBSCRIBE_PORT=4443
      - SE_NODE_MAX_SESSIONS=5
      - SE_NODE_OVERRIDE_MAX_SESSIONS=true
      - SE_NODE_HEADLESS=true
    networks:
      - grid

networks:
  grid:
    driver: bridge
